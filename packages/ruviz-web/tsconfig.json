{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmitOnError": true,
    "useDefineForClassFields": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts"
  ]
}

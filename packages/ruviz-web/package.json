{
  "name": "ruviz",
  "version": "0.4.5",
  "description": "Browser-first JS/TS SDK for ruviz WebAssembly rendering",
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ameyanagi/ruviz.git"
  },
  "homepage": "https://github.com/Ameyanagi/ruviz",
  "bugs": {
    "url": "https://github.com/Ameyanagi/ruviz/issues"
  },
  "files": [
    "README.md",
    "dist/index.d.ts",
    "dist/index.js",
    "dist/index.js.map",
    "dist/plot-runtime.d.ts",
    "dist/plot-runtime.js",
    "dist/plot-runtime.js.map",
    "dist/session-worker.d.ts",
    "dist/session-worker.js",
    "dist/session-worker.js.map",
    "dist/shared.d.ts",
    "dist/shared.js",
    "dist/shared.js.map",
    "generated/raw/LICENSE",
    "generated/raw/package.json",
    "generated/raw/README.md",
    "generated/raw/ruviz_web_raw_bg.wasm",
    "generated/raw/ruviz_web_raw_bg.wasm.d.ts",
    "generated/raw/ruviz_web_raw.d.ts",
    "generated/raw/ruviz_web_raw.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./raw": {
      "types": "./generated/raw/ruviz_web_raw.d.ts",
      "import": "./generated/raw/ruviz_web_raw.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:raw": "bash ./scripts/build-raw.sh",
    "build:wasm": "bash ./scripts/build-wasm.sh",
    "build:js": "tsc -p tsconfig.json",
    "build": "bun run build:wasm && bun run build:js",
    "docs:api": "typedoc",
    "docs:dev": "bun run build:wasm && bun run docs:api && vitepress dev docs",
    "docs:build": "bun run build:wasm && bun run docs:api && bun run docs:build:preview",
    "docs:build:preview": "RUVIZ_WEB_DOCS_BASE=./ vitepress build docs --outDir ../../generated/web/docs",
    "docs:preview": "vitepress preview docs",
    "pack:dry": "bun pm pack --dry-run"
  },
  "devDependencies": {
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.9.2",
    "vitepress": "^2.0.0-alpha.12"
  }
}

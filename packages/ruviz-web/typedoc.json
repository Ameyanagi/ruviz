{
  "entryPoints": [
    "src/index.ts",
    "src/shared.ts"
  ],
  "out": "docs/api/reference",
  "plugin": [
    "typedoc-plugin-markdown"
  ],
  "sourceLinkTemplate": "https://github.com/Ameyanagi/ruviz/blob/main/{path}#L{line}",
  "readme": "none",
  "hideGenerator": true,
  "intentionallyNotExported": [
    "PlotState",
    "XYSeriesInput",
    "BarSeriesInput",
    "ContourInput",
    "ErrorBarsInput",
    "ErrorBarsXYInput",
    "PolarLineInput",
    "RadarInput"
  ],
  "excludePrivate": true,
  "excludeInternal": true
}
